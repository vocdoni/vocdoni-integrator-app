# Base URL of the Vocdoni SaaS backend API (no trailing slash).
# Dev:  https://saas-api-dev.vocdoni.net
VITE_SAAS_URL=https://saas-api-dev.vocdoni.net

# Stripe publishable key, used to render the plan-upgrade checkout.
# Optional: when unset, the upgrade UI shows a "payments unavailable" message.
VITE_STRIPE_PUBLISHABLE_KEY=
